{
  "AgentService": {
    "_comment": "Keep this service non-interactive. It uploads helper snapshots and must not capture raw input or private content on its own.",
    "_contractNote": "SessionHelperPipeName must match SessionHelper:PipeName. DryRun=true is the safest default for local contract and deployment testing.",
    "_tokenNote": "Use an issued device-scoped v2:<device_id>:<secret> token for production. Raw signing secrets and legacy v1 tokens are development/test compatibility paths only.",
    "_tokenStorageNote": "Prefer ProtectedTokenPath populated with the publish helper script or a DPAPI PowerShell command. ApiToken remains a dev fallback for local runs and AGENT_AgentService__ApiToken overrides.",
    "ApiBaseUrl": "https://backend.example.internal",
    "ProtectedTokenPath": "C:\\ProgramData\\EmployeeBehaviorAgent\\secrets\\agent-token.protected.json",
    "ApiToken": "",
    "DryRun": true,
    "EmployeeId": null,
    "DeviceIdPath": "C:\\ProgramData\\EmployeeBehaviorAgent\\device-id.json",
    "SessionHelperPipeName": "employee-behavior-agent",
    "SessionHelperConnectTimeoutSeconds": 3,
    "SessionHelperRequestTimeoutSeconds": 30,
    "HeartbeatIntervalSeconds": 30,
    "PolicyRefreshIntervalSeconds": 300,
    "UploadPollIntervalSeconds": 5,
    "UploadBatchSize": 2,
    "UploadQueuePath": "C:\\ProgramData\\EmployeeBehaviorAgent\\upload-queue.jsonl",
    "UploadQueueLeaseDurationSeconds": 300,
    "_deploymentNote": "After local DryRun verification, set DryRun=false and validate heartbeat plus screenshot upload against the target backend.",
    "_queueNote": "UploadQueuePath is a persistent JSONL queue. Keep it on local disk so pending uploads survive service restarts.",
    "DefaultPolicy": {
      "Version": "bootstrap",
      "CaptureEnabled": true,
      "ScreenshotIntervalSeconds": 10,
      "NoChangeThreshold": 6,
      "HighRiskDurationMinutes": 5,
      "GithubRiskWeight": "high",
      "FileTransferRiskWeight": "high",
      "NormalApps": [ "IDE", "Terminal", "Browser", "Git Client", "Database Tool" ],
      "LowChangeContexts": [ "documentation", "terminal", "code_review" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
