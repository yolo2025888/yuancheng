<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Employee Behavior Agent Installer"
    Manufacturer="Employee Behavior Monitor"
    Version="0.1.0.0"
    UpgradeCode="6E989DD3-2BD9-48F5-82C4-C8375AE6F550"
    Language="1033"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">
    <SummaryInformation Description="Stages the Employee Behavior Agent installer package under Program Files for operator-driven install, validation, and rollback." />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Employee Behavior Agent Installer is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="RUNPACKAGEDINSTALL" Value="0" Secure="yes" />
    <Property Id="HELPERTASKUSER" Secure="yes" />
    <Property Id="RUNPACKAGEDUNINSTALL" Value="1" Secure="yes" />

    <SetProperty
      Id="RunPackagedInstall"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]Invoke-MsiPackagedInstall.ps1&quot; -PackageRoot &quot;[INSTALLFOLDER]&quot; -HelperTaskUser &quot;[HELPERTASKUSER]&quot;"
      Before="RunPackagedInstall"
      Sequence="execute"
      Condition="NOT Installed AND RUNPACKAGEDINSTALL=1 AND HELPERTASKUSER" />

    <CustomAction
      Id="RunPackagedInstall"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <SetProperty
      Id="RunPackagedUninstall"
      Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]Invoke-MsiPackagedUninstall.ps1&quot; -PackageRoot &quot;[INSTALLFOLDER]&quot; -RemoveInstalledFiles"
      Before="RunPackagedUninstall"
      Sequence="execute"
      Condition="REMOVE~=&quot;ALL&quot; AND RUNPACKAGEDUNINSTALL=1" />

    <CustomAction
      Id="RunPackagedUninstall"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="COMPANYDIR" Name="EmployeeBehaviorAgent">
        <Directory Id="INSTALLFOLDER" Name="InstallerPackage" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Employee Behavior Agent Installer Package" Level="1">
      <ComponentGroupRef Id="InstallerPayloadGroup" />
    </Feature>

    <InstallExecuteSequence>
      <Custom Action="RunPackagedInstall" After="InstallFiles" Condition="NOT Installed AND RUNPACKAGEDINSTALL=1 AND HELPERTASKUSER" />
      <Custom Action="RunPackagedUninstall" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot; AND RUNPACKAGEDUNINSTALL=1" />
    </InstallExecuteSequence>
  </Package>
</Wix>
