# Backend (FastAPI reads only EBM_* settings)
# Replace every replace-with-* placeholder before production starts.
EBM_ENVIRONMENT=production
EBM_API_PREFIX=/api
EBM_DATABASE_URL=postgresql+psycopg://replace-with-local-postgres-user:replace-with-local-postgres-password@localhost:5432/employee_monitor
EBM_STORAGE_ROOT_DIR=storage
EBM_AUTH_SECRET=replace-with-32-plus-character-auth-secret
EBM_AGENT_API_TOKEN=replace-with-24-plus-character-agent-token
EBM_BOOTSTRAP_ADMIN_USERNAME=admin
EBM_BOOTSTRAP_ADMIN_PASSWORD=replace-with-initial-admin-password
EBM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Initial Admin
EBM_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
EBM_SESSION_TOKEN_TTL_SECONDS=43200

# Local service infrastructure
POSTGRES_DB=employee_monitor
POSTGRES_USER=replace-with-local-postgres-user
POSTGRES_PASSWORD=replace-with-local-postgres-password
REDIS_URL=redis://localhost:6379/0

# Object storage for local dependencies
MINIO_ROOT_USER=replace-with-local-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-local-minio-root-password

# Agent
AGENT_API_BASE_URL=http://localhost:8010
AGENT_HEARTBEAT_SECONDS=30
AGENT_SCREENSHOT_INTERVAL_SECONDS=10
AGENT_NO_CHANGE_THRESHOLD=6

# Frontend
VITE_API_BASE_URL=http://localhost:8010

# GitHub integration
GITHUB_ORG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_TOKEN=
